<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ══════════════════════════════════════════════════════════════════════
         NETWORK
         ══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ══════════════════════════════════════════════════════════════════════
         BLUETOOTH / BLE
         Android 12+ (API 31+): new granular permissions
         ══════════════════════════════════════════════════════════════════════ -->
    <!-- Scan for nearby BLE devices. neverForLocation = no location inference -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31" />
    <!-- Connect/pair with BLE peers -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31" />
    <!-- Advertise this device as a BLE peripheral -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADVERTISE"
        tools:targetApi="31" />

    <!-- Android 11 and below: classic BLE permissions (maxSdkVersion caps them) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- ══════════════════════════════════════════════════════════════════════
         LOCATION  (required by BLE scanning on all Android versions)
         ══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Background location allows BLE mesh to continue scanning when the
         app is pushed to the background / enters Doze mode -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ══════════════════════════════════════════════════════════════════════
         FOREGROUND SERVICE
         Android 14 (API 34) requires declaring the service type in both the
         permission element AND the <service> tag.
         ══════════════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- connectedDevice type covers BLE GATT / HFP / etc. -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:targetApi="34" />

    <!-- ══════════════════════════════════════════════════════════════════════
         MISC
         ══════════════════════════════════════════════════════════════════════ -->
    <!-- Vibrate on SOS alert -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Keep CPU running while BLE scanning in background (Doze bypass) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Schedule exact alarms that fire even in deep Doze mode (Fix 1B).
         USE_EXACT_ALARM: auto-granted for safety/communication apps on API 33+.
         SCHEDULE_EXACT_ALARM: user-approval variant on API 31-32; we fall back
         to setAndAllowWhileIdle (inexact but Doze-exempt) if not granted. -->
    <uses-permission
        android:name="android.permission.USE_EXACT_ALARM"
        tools:targetApi="33" />
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:targetApi="31" />
    <!-- POST_NOTIFICATIONS: required on Android 13+ to show FCM / SOS banners -->
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />

    <!-- ══════════════════════════════════════════════════════════════════════
         HARDWARE FEATURES
         android:required="true" means the Play Store will only show VEXT
         on devices with a BLE chip.
         ══════════════════════════════════════════════════════════════════════ -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:label="VEXT"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── flutter_background_service foreground type override ──────────────
             The plugin declares BackgroundService in its own AndroidManifest
             without a foregroundServiceType attribute. On Android 14 (API 34+)
             with targetSdk 34+, calling startForeground() without a declared
             type throws a ForegroundServiceTypeNotAllowedException and crashes
             the app on screen-off.

             tools:node="merge" merges our attributes onto the plugin's existing
             <service> declaration instead of re-declaring it (which would cause
             a "duplicate service" manifest merger conflict on android:exported).

             connectedDevice covers BLE GATT connections, HFP, and A2DP — the
             correct type for a BLE mesh foreground service.

             FOREGROUND_SERVICE_CONNECTED_DEVICE permission is already declared
             above in the <uses-permission> block.
             ──────────────────────────────────────────────────────────────── -->
        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            android:foregroundServiceType="connectedDevice"
            tools:node="merge" />

        <!-- ── VextAlarmReceiver — deep-Doze BLE scan restarter (Fix 1B) ─────────
             Receives the setExactAndAllowWhileIdle alarm and pushes a
             "scanRestart" event to BleTransportLayer via the alarm_events
             EventChannel. android:exported="false" — only the system AlarmManager
             (which has implicit access) needs to broadcast to this receiver.
             ──────────────────────────────────────────────────────────────── -->
        <receiver
            android:name=".VextAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.vext.vext_app.DOZE_SCAN_RESTART" />
            </intent-filter>
        </receiver>

        <!-- Flutter tool meta-data — do not delete -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- Required for Flutter text processing plugin -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

</manifest>
